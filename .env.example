# =============================================================================
# .env.example
# -----------------------------------------------------------------------------
# Per the brief: ".env holds only the Vault root token and ports."
# EVERY real secret (LLM keys, JWT signing key, DB password, MinIO creds,
# tracing keys) resolves from Vault at startup — it must NOT live here.
#
# Usage: `cp .env.example .env` then fill in VAULT_DEV_ROOT_TOKEN.
# `docker-compose up` must come up cleanly from a fresh clone after this.
# =============================================================================

# ---- Vault (the ONLY secret allowed in this file) ----------------------------
VAULT_DEV_ROOT_TOKEN=changeme-dev-root-token
VAULT_ADDR=http://vault:8200

# ---- Service ports (non-secret) ----------------------------------------------
API_PORT=8000
MODELSERVER_PORT=8001
CHATBOT_PORT=8501
WIDGET_PORT=8080
HOST_DEMO_PORT=8090
DB_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
VAULT_PORT=8200

# ---- Non-secret service coordinates (hostnames inside the compose network) ----
# Real credentials for these are pulled from Vault, not set here.
DB_HOST=db
DB_NAME=copilot
REDIS_HOST=redis
MINIO_ENDPOINT=minio:9000
MODELSERVER_URL=http://modelserver:8001
